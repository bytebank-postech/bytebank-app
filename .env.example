# Internal URLs used while building the shell image for Docker Compose.
MFE_HOME_URL=http://mfe-home:3000
MFE_TRANSACTIONS_URL=http://mfe-transactions:3000
MFE_AUTH_URL=http://mfe-auth:3000

# Use a strong value in cloud environments. The Compose default is only for local testing.
JWT_SECRET=bytebank-local-development-secret
COOKIE_SECURE=false

# Public host port for the shell gateway.
SHELL_PORT=3000
